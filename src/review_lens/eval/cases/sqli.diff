diff --git a/api/orders.py b/api/orders.py
index 1111111..2222222 100644
--- a/api/orders.py
+++ b/api/orders.py
@@ -1,3 +1,12 @@
 import sqlite3


+def find_orders(db: sqlite3.Connection, customer: str) -> list[tuple]:
+    query = "SELECT id, total FROM orders WHERE customer = '" + customer + "'"
+    cur = db.execute(query)
+    return cur.fetchall()
+
+
+def order_count(db: sqlite3.Connection, customer: str) -> int:
+    return len(find_orders(db, customer))
+
