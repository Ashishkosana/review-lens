 import sqlite3


+def get_user(db: sqlite3.Connection, username: str) -> dict:
+    cur = db.execute(f"SELECT id, email FROM users WHERE username = '{username}'")
+    row = cur.fetchone()
+    return {"id": row[0], "email": row[1]}
+
+
+def is_admin(db: sqlite3.Connection, username: str) -> bool:
+    user = get_user(db, username)
+    return user["email"].endswith("@admin.example.com")
+
+
